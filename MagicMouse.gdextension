[configuration]
entry_symbol = "gdext_magic_mouse"
compatibility_minimum = 4.5
reloadable = true

[libraries]
linux.debug.x86_64 =     "res://addons/spacemouse2/lib/libgodot-magicmouse.so"
linux.release.x86_64 =   "res://addons/spacemouse2/lib/libgodot-magicmouse.so"
windows.debug.x86_64 =   "res://addons/spacemouse2/lib/godot_magicmouse.dll"
windows.release.x86_64 = "res://addons/spacemouse2/lib/godot_magicmouse.dll"
macos.debug =            "res://addons/spacemouse2/lib/libgodot-magicmouse.dylib"
macos.release =          "res://addons/spacemouse2/lib/libgodot-magicmouse.dylib"
macos.debug.arm64 =      "res://addons/spacemouse2/lib/libgodot-magicmouse.dylib"
macos.release.arm64 =    "res://addons/spacemouse2/lib/libgodot-magicmouse.dylib"
